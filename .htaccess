# ══════════════════════════════════════════════════════════════════════════════
#  Book Spire Publishing — Apache .htaccess
#  GoDaddy Shared Hosting (Apache + PHP)
# ══════════════════════════════════════════════════════════════════════════════

Options -Indexes
Options +FollowSymLinks

RewriteEngine On

# ── 1. Force HTTPS ────────────────────────────────────────────────────────────
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ── 2. Force www (canonical domain) ──────────────────────────────────────────
# Uncomment whichever you prefer (www vs non-www).
# With www:
# RewriteCond %{HTTP_HOST} !^www\. [NC]
# RewriteRule ^ https://www.%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
# Without www (non-www canonical):
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# ── 3. Redirect old .html URLs → .php (301 permanent, SEO-safe) ───────────────
# Handles requests for any page.html that now lives as page.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([a-z][a-z0-9\-]*)\.html$ /$1.php [L,R=301]

# ── 4. Redirect /index.php → / (clean home URL) ──────────────────────────────
RewriteRule ^index\.php$ / [L,R=301]

# ── 5. Default document ───────────────────────────────────────────────────────
DirectoryIndex index.php index.html

# ── 6. Custom error pages ────────────────────────────────────────────────────
# Uncomment and create these pages if desired:
# ErrorDocument 404 /404.php
# ErrorDocument 500 /500.php

# ── 7. PHP file handling (Apache serves .php directly) ───────────────────────
# GoDaddy shared hosting handles PHP natively; no extra config needed.

# ── 8. Security headers ───────────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── 9. Gzip compression ───────────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/x-javascript
    AddOutputFilterByType DEFLATE application/json image/svg+xml
</IfModule>

# ── 10. Browser caching ───────────────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg         "access plus 1 year"
    ExpiresByType image/png          "access plus 1 year"
    ExpiresByType image/webp         "access plus 1 year"
    ExpiresByType image/svg+xml      "access plus 1 year"
    ExpiresByType image/gif          "access plus 1 year"
    ExpiresByType text/css           "access plus 3 months"
    ExpiresByType application/javascript "access plus 3 months"
    ExpiresByType text/html          "access plus 1 day"
</IfModule>
